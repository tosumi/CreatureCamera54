{
  "expo": {
    "name": "CreatureCamera54",
    "slug": "CreatureCamera54",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a0a00"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "生き物を呼び寄せるためにカメラを使います",
        "NSPhotoLibraryAddUsageDescription": "生き物と一緒に撮った写真を保存します",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.tosumi.CreatureCamera"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f049871f-78b9-49fb-97f6-8f0b30839d58"
      }
    }
  }
}
